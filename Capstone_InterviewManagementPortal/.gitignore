# ==========================================
# Root Git Ignore for Capstone Project
# ==========================================

# Dependency directories
node_modules/
frontend/node_modules/

# Build outputs
dist/
frontend/dist/
dist-ssr/
frontend/dist-ssr/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
backend/.env

# Logs
*.log
backend/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
db.sqlite3

# IDEs/Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# Backend Specific (Python)
# ==========================================

# Byte-compiled / optimized / DLL files
__pycache__/
backend/__pycache__/
*.py[cod]
*$py.class

# Pytest / Testing
.pytest_cache/
backend/.pytest_cache/
.htmlcov/
.coverage
htmlcov/

# Python Virtual Environments
.venv/
venv/
ENV/
env/


# additional files to ignore
backend/uploads/**/*
seed_db.py
